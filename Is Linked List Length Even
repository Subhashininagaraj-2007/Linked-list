
class Node {
    int data;
    Node next;

    Node(int data) {
        this.data = data;
        this.next = null;
    }
}
class Solution {
    public boolean isEven(Node head) {
        // code here
        int count=0;
        Node temp=head;
        while(temp!=null)
        {  
            temp=temp.next;
            count++;
        }
        if(count%2==0)
        {
            return true;
        }
        return false;
    }
}
